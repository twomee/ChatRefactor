# Auth Service — Environment Variables
# Copy this to .env and fill in values for local development.

# Application environment: dev | staging | prod
APP_ENV=dev

# PostgreSQL connection string (auth service uses chatbox_auth database)
DATABASE_URL=postgresql://chatbox:chatbox_pass@localhost:5432/chatbox_auth

# Redis connection string (used for token blacklisting)
REDIS_URL=redis://localhost:6379/0

# Kafka bootstrap servers (used for auth event production)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# JWT secret key — MUST be changed in production
SECRET_KEY=change-this-in-production

# JWT algorithm and token expiry
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# Default admin credentials — MUST be changed in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
