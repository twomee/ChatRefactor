# Chat Service Configuration
# Copy to .env and fill in real values.

APP_ENV=dev
PORT=8003
LOG_LEVEL=info

# PostgreSQL — the chat-service owns chatbox_chat
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatbox_chat

# Redis — used for WebSocket pub/sub (future horizontal scaling)
REDIS_URL=redis://localhost:6379/0

# Kafka — message bus for persistence and cross-service events
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Shared JWT secret — must match auth-service
SECRET_KEY=change-this-in-production

# Downstream service URLs
AUTH_SERVICE_URL=http://localhost:8001
MESSAGE_SERVICE_URL=http://localhost:8002
