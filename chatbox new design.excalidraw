      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "JWT: HS256, 24h expiry\nArgon2id password hash\n(replaces old MD5/SHA)\n\nDependencies:\nrequire_auth() - any user\nrequire_admin() - admin only\n\nCORS configured\nfor React origin",
      "autoResize": true,
      "lineHeight": 1.25
