# Chatbox K8s Secrets Configuration
# Copy this file to secrets.env and fill in real values
# Then run: make k8s-secrets

# PostgreSQL password (used by all services)
POSTGRES_PASSWORD=chatbox_pass

# Redis password (used by auth-service, chat-service)
REDIS_PASSWORD=chatbox_redis_pass

# JWT signing secret (shared across all services, MUST be the same)
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Admin bootstrap credentials (auth-service only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
