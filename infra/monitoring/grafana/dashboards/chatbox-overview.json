          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total{job=~\"auth-service|chat-service|message-service|file-service\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=~\"auth-service|chat-service|message-service|file-service\"}[5m])) * 100",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
