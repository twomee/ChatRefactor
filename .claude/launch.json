{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5173", "--host"],
      "port": 5173,
      "cwd": "frontend",
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "cwd": "backend",
      "autoPort": false
    }
  ]
}
