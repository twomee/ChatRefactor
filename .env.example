# App environment: dev | staging | prod
APP_ENV=dev

# PostgreSQL (shared instance, per-service databases created by init-databases.sh)
POSTGRES_PASSWORD=chatbox_pass

# Redis authentication
REDIS_PASSWORD=chatbox_redis_pass

# Shared secret for JWT signing (all services must use the same key)
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Admin bootstrap credentials (auth-service)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# CORS (comma-separated origins, used by Kong and individual services)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --------------------------------------------------------------------------
# Local development overrides (used when running services outside Docker)
# --------------------------------------------------------------------------

# Auth Service
# DATABASE_URL=postgresql://chatbox:chatbox_pass@localhost:5432/chatbox_auth
# REDIS_URL=redis://localhost:6379/0
# KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Chat Service (Go)
# DATABASE_URL=postgresql://chatbox:chatbox_pass@localhost:5432/chatbox_chat
# REDIS_URL=redis://localhost:6379/0
# KAFKA_BOOTSTRAP_SERVERS=localhost:29092
# AUTH_SERVICE_URL=http://localhost:8001
# MESSAGE_SERVICE_URL=http://localhost:8004

# Message Service
# DATABASE_URL=postgresql://chatbox:chatbox_pass@localhost:5432/chatbox_messages
# KAFKA_BOOTSTRAP_SERVERS=localhost:29092
# AUTH_SERVICE_URL=http://localhost:8001

# File Service (Node.js)
# DATABASE_URL=postgresql://chatbox:chatbox_pass@localhost:5432/chatbox_files
# KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Frontend (used during Vite build)
VITE_API_BASE=http://localhost
VITE_WS_BASE=ws://localhost
